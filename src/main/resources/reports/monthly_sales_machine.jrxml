<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="monthly_sales_machine" pageWidth="1080" pageHeight="595" orientation="Landscape" columnWidth="1040" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
    <parameter name="REPORT_TITLE" class="java.lang.String"/>
    <parameter name="DATE_FROM" class="java.sql.Date"/>
    <parameter name="DATE_TO" class="java.sql.Date"/>
    <parameter name="FROM_YM" class="java.lang.Integer"/>
    <parameter name="TO_YM" class="java.lang.Integer"/>
    <parameter name="HEADER_REGISTERED_NAME" class="java.lang.String"/>
    <parameter name="HEADER_TRADE_NAME" class="java.lang.String"/>
    <parameter name="HEADER_TIN" class="java.lang.String"/>
    <parameter name="HEADER_BRANCH_CODE" class="java.lang.String"/>
    <parameter name="HEADER_BUSINESS_ADDRESS" class="java.lang.String"/>
    <parameter name="HEADER_PTU_NO" class="java.lang.String"/>
    <parameter name="HEADER_ATP_NO" class="java.lang.String"/>
    <parameter name="HEADER_POS_VENDOR" class="java.lang.String"/>
    <parameter name="PRINTED_BY" class="java.lang.String"/>
    <parameter name="PRINTED_AT" class="java.lang.String"/>
    <queryString><![CDATA[
        SELECT year_no AS YEAR_NO,
               month_no AS MONTH_NO,
               store_code AS STORE_CODE,
               machine_code AS MACHINE_CODE,
               seller_tin_no || '-' || seller_branch_code AS SELLER_TIN_BRANCH,
               invoice_count AS INVOICE_COUNT,
               first_serial_no AS FIRST_SERIAL_NO,
               last_serial_no AS LAST_SERIAL_NO,
               gross_sales AS GROSS_SALES,
               vatable_sales AS VATABLE_SALES,
               vat_amount AS VAT_AMOUNT,
               vat_exempt_sales AS VAT_EXEMPT_SALES,
               zero_rated_sales AS ZERO_RATED_SALES,
               discount_total AS DISCOUNT_TOTAL,
               withholding_tax_amount AS WITHHOLDING_TAX_AMOUNT,
               total_amount_due AS TOTAL_AMOUNT_DUE
        FROM v_bir_monthly_machine_sales
        WHERE (year_no * 100 + month_no) BETWEEN $P{FROM_YM} AND $P{TO_YM}
        ORDER BY year_no, month_no, store_code, machine_code
    ]]></queryString>
    <field name="YEAR_NO" class="java.lang.Integer"/>
    <field name="MONTH_NO" class="java.lang.Integer"/>
    <field name="STORE_CODE" class="java.lang.String"/>
    <field name="MACHINE_CODE" class="java.lang.String"/>
    <field name="SELLER_TIN_BRANCH" class="java.lang.String"/>
    <field name="INVOICE_COUNT" class="java.lang.Integer"/>
    <field name="FIRST_SERIAL_NO" class="java.lang.Long"/>
    <field name="LAST_SERIAL_NO" class="java.lang.Long"/>
    <field name="GROSS_SALES" class="java.math.BigDecimal"/>
    <field name="VATABLE_SALES" class="java.math.BigDecimal"/>
    <field name="VAT_AMOUNT" class="java.math.BigDecimal"/>
    <field name="VAT_EXEMPT_SALES" class="java.math.BigDecimal"/>
    <field name="ZERO_RATED_SALES" class="java.math.BigDecimal"/>
    <field name="DISCOUNT_TOTAL" class="java.math.BigDecimal"/>
    <field name="WITHHOLDING_TAX_AMOUNT" class="java.math.BigDecimal"/>
    <field name="TOTAL_AMOUNT_DUE" class="java.math.BigDecimal"/>
    <title>
        <band height="92">
            <textField><reportElement x="0" y="0" width="1180" height="20"/><textElement textAlignment="Center"><font size="14" isBold="true"/></textElement><textFieldExpression><![CDATA[$P{REPORT_TITLE}]]></textFieldExpression></textField>
            <textField><reportElement x="0" y="20" width="1180" height="16"/><textElement textAlignment="Center"><font size="10"/></textElement><textFieldExpression><![CDATA["Period: " + $P{DATE_FROM} + " to " + $P{DATE_TO}]]></textFieldExpression></textField>
            <textField><reportElement x="0" y="38" width="1180" height="16"/><textElement textAlignment="Center"><font size="10" isBold="true"/></textElement><textFieldExpression><![CDATA[$P{HEADER_REGISTERED_NAME} + ($P{HEADER_TRADE_NAME} == null || $P{HEADER_TRADE_NAME}.trim().isEmpty() ? "" : " / " + $P{HEADER_TRADE_NAME})]]></textFieldExpression></textField>
            <textField><reportElement x="0" y="54" width="1180" height="16"/><textElement textAlignment="Center"><font size="9"/></textElement><textFieldExpression><![CDATA["TIN: " + $P{HEADER_TIN} + ($P{HEADER_BRANCH_CODE} == null || $P{HEADER_BRANCH_CODE}.trim().isEmpty() ? "" : "    Branch: " + $P{HEADER_BRANCH_CODE}) + "    Address: " + $P{HEADER_BUSINESS_ADDRESS}]]></textFieldExpression></textField>
            <textField><reportElement x="0" y="70" width="1180" height="16"/><textElement textAlignment="Center"><font size="9"/></textElement><textFieldExpression><![CDATA["PTU No: " + $P{HEADER_PTU_NO} + "    ATP No: " + $P{HEADER_ATP_NO} + ($P{HEADER_POS_VENDOR} == null || $P{HEADER_POS_VENDOR}.trim().isEmpty() ? "" : "    POS Vendor: " + $P{HEADER_POS_VENDOR})]]></textFieldExpression></textField>
        </band>
    </title>
    <columnHeader>
        <band height="20">
            <staticText><reportElement x="0" y="0" width="45" height="20"/><text><![CDATA[Year]]></text></staticText>
            <staticText><reportElement x="45" y="0" width="45" height="20"/><text><![CDATA[Mon]]></text></staticText>
            <staticText><reportElement x="90" y="0" width="55" height="20"/><text><![CDATA[Store]]></text></staticText>
            <staticText><reportElement x="145" y="0" width="70" height="20"/><text><![CDATA[Machine]]></text></staticText>
            <staticText><reportElement x="215" y="0" width="115" height="20"/><text><![CDATA[TIN/Branch]]></text></staticText>
            <staticText><reportElement x="330" y="0" width="55" height="20"/><text><![CDATA[Inv]]></text></staticText>
            <staticText><reportElement x="385" y="0" width="70" height="20"/><text><![CDATA[First Ser]]></text></staticText>
            <staticText><reportElement x="455" y="0" width="70" height="20"/><text><![CDATA[Last Ser]]></text></staticText>
            <staticText><reportElement x="525" y="0" width="80" height="20"/><text><![CDATA[Gross]]></text></staticText>
            <staticText><reportElement x="605" y="0" width="80" height="20"/><text><![CDATA[Vatable]]></text></staticText>
            <staticText><reportElement x="685" y="0" width="75" height="20"/><text><![CDATA[VAT]]></text></staticText>
            <staticText><reportElement x="760" y="0" width="75" height="20"/><text><![CDATA[Exempt]]></text></staticText>
            <staticText><reportElement x="835" y="0" width="75" height="20"/><text><![CDATA[Zero]]></text></staticText>
            <staticText><reportElement x="910" y="0" width="60" height="20"/><text><![CDATA[Disc]]></text></staticText>
            <staticText><reportElement x="970" y="0" width="70" height="20"/><text><![CDATA[Total Due]]></text></staticText>
        </band>
    </columnHeader>
    <detail>
        <band height="20">
            <rectangle>
                <reportElement x="0" y="0" width="1040" height="20" mode="Opaque" backcolor="#F2F2F2">
                    <printWhenExpression><![CDATA[Boolean.valueOf($V{REPORT_COUNT}.intValue() % 2 == 0)]]></printWhenExpression>
                </reportElement>
                <graphicElement/>
            </rectangle>
            <textField><reportElement x="0" y="0" width="45" height="20"/><textFieldExpression><![CDATA[$F{YEAR_NO}]]></textFieldExpression></textField>
            <textField><reportElement x="45" y="0" width="45" height="20"/><textFieldExpression><![CDATA[$F{MONTH_NO}]]></textFieldExpression></textField>
            <textField><reportElement x="90" y="0" width="55" height="20"/><textFieldExpression><![CDATA[$F{STORE_CODE}]]></textFieldExpression></textField>
            <textField><reportElement x="145" y="0" width="70" height="20"/><textFieldExpression><![CDATA[$F{MACHINE_CODE}]]></textFieldExpression></textField>
            <textField><reportElement x="215" y="0" width="115" height="20"/><textFieldExpression><![CDATA[$F{SELLER_TIN_BRANCH}]]></textFieldExpression></textField>
            <textField><reportElement x="330" y="0" width="55" height="20"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{INVOICE_COUNT}]]></textFieldExpression></textField>
            <textField><reportElement x="385" y="0" width="70" height="20"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{FIRST_SERIAL_NO}]]></textFieldExpression></textField>
            <textField><reportElement x="455" y="0" width="70" height="20"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{LAST_SERIAL_NO}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="525" y="0" width="80" height="20"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{GROSS_SALES}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="605" y="0" width="80" height="20"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{VATABLE_SALES}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="685" y="0" width="75" height="20"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{VAT_AMOUNT}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="760" y="0" width="75" height="20"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{VAT_EXEMPT_SALES}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="835" y="0" width="75" height="20"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{ZERO_RATED_SALES}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="910" y="0" width="60" height="20"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{DISCOUNT_TOTAL}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="970" y="0" width="70" height="20"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{TOTAL_AMOUNT_DUE}]]></textFieldExpression></textField>
        </band>
    </detail>

    <pageFooter>
        <band height="18">
            <textField><reportElement x="0" y="0" width="590" height="16"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA["Printed By: " + $P{PRINTED_BY}]]></textFieldExpression></textField>
            <textField><reportElement x="590" y="0" width="590" height="16"/><textElement textAlignment="Right"><font size="9"/></textElement><textFieldExpression><![CDATA["Printed At: " + $P{PRINTED_AT}]]></textFieldExpression></textField>
        </band>
    </pageFooter>
</jasperReport>
