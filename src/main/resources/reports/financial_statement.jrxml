            <staticText><reportElement x="1100" y="0" width="80" height="20"/><text><![CDATA[Adjust]]></text></staticText>
        </band>
    </columnHeader>
    <detail>
        <band height="20">
            <rectangle>
                <reportElement x="0" y="0" width="1180" height="20" mode="Opaque" backcolor="#F2F2F2">
                    <printWhenExpression><![CDATA[Boolean.valueOf($V{REPORT_COUNT}.intValue() % 2 == 0)]]></printWhenExpression>
                </reportElement>
                <graphicElement/>
            </rectangle>
            <textField pattern="yyyy-MM-dd"><reportElement x="0" y="0" width="75" height="20"/><textFieldExpression><![CDATA[$F{BUSINESS_DATE}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="75" y="0" width="85" height="20"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{GROSS_SALES}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="160" y="0" width="85" height="20"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{SALES_DISCOUNT}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="245" y="0" width="85" height="20"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{SALES_NET}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="330" y="0" width="80" height="20"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{OUTPUT_VAT}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="410" y="0" width="85" height="20"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{SALES_RETURNS}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="495" y="0" width="100" height="20"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{NET_SALES_AFTER_RETURNS}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="595" y="0" width="100" height="20"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{NET_COST_OF_GOODS_SOLD}]]></textFieldExpression></textField>
