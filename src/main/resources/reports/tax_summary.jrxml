<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="tax_summary" pageWidth="1080" pageHeight="595" orientation="Landscape" columnWidth="1040" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
    <parameter name="REPORT_TITLE" class="java.lang.String"/>
    <parameter name="DATE_FROM" class="java.sql.Date"/>
    <parameter name="DATE_TO" class="java.sql.Date"/>
    <parameter name="HEADER_REGISTERED_NAME" class="java.lang.String"/>
    <parameter name="HEADER_TRADE_NAME" class="java.lang.String"/>
    <parameter name="HEADER_TIN" class="java.lang.String"/>
    <parameter name="HEADER_BRANCH_CODE" class="java.lang.String"/>
    <parameter name="HEADER_BUSINESS_ADDRESS" class="java.lang.String"/>
    <parameter name="HEADER_PTU_NO" class="java.lang.String"/>
    <parameter name="HEADER_ATP_NO" class="java.lang.String"/>
    <parameter name="HEADER_POS_VENDOR" class="java.lang.String"/>
    <parameter name="PRINTED_BY" class="java.lang.String"/>
    <parameter name="PRINTED_AT" class="java.lang.String"/>
    <queryString><![CDATA[
        SELECT business_date AS BUSINESS_DATE,
               store_code AS STORE_CODE,
               terminal_code AS TERMINAL_CODE,
               invoice_count AS INVOICE_COUNT,
               void_invoice_count AS VOID_INVOICE_COUNT,
               gross_sales AS GROSS_SALES,
               vatable_sales AS VATABLE_SALES,
               vat_amount AS VAT_AMOUNT,
               vat_exempt_sales AS VAT_EXEMPT_SALES,
               zero_rated_sales AS ZERO_RATED_SALES,
               withholding_tax_amount AS WITHHOLDING_TAX_AMOUNT,
               discount_total AS DISCOUNT_TOTAL,
               total_amount_due AS TOTAL_AMOUNT_DUE
        FROM v_bir_tax_summary
        WHERE business_date BETWEEN $P{DATE_FROM} AND $P{DATE_TO}
        ORDER BY business_date, store_code, terminal_code
    ]]></queryString>
    <field name="BUSINESS_DATE" class="java.sql.Date"/>
    <field name="STORE_CODE" class="java.lang.String"/>
    <field name="TERMINAL_CODE" class="java.lang.String"/>
    <field name="INVOICE_COUNT" class="java.lang.Integer"/>
    <field name="VOID_INVOICE_COUNT" class="java.lang.Integer"/>
    <field name="GROSS_SALES" class="java.math.BigDecimal"/>
    <field name="VATABLE_SALES" class="java.math.BigDecimal"/>
    <field name="VAT_AMOUNT" class="java.math.BigDecimal"/>
    <field name="VAT_EXEMPT_SALES" class="java.math.BigDecimal"/>
    <field name="ZERO_RATED_SALES" class="java.math.BigDecimal"/>
    <field name="WITHHOLDING_TAX_AMOUNT" class="java.math.BigDecimal"/>
    <field name="DISCOUNT_TOTAL" class="java.math.BigDecimal"/>
    <field name="TOTAL_AMOUNT_DUE" class="java.math.BigDecimal"/>
    <variable name="GROSS_SALES_SUM" class="java.math.BigDecimal" calculation="Sum"><variableExpression><![CDATA[$F{GROSS_SALES}]]></variableExpression><initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression></variable>
    <variable name="VATABLE_SALES_SUM" class="java.math.BigDecimal" calculation="Sum"><variableExpression><![CDATA[$F{VATABLE_SALES}]]></variableExpression><initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression></variable>
    <variable name="VAT_AMOUNT_SUM" class="java.math.BigDecimal" calculation="Sum"><variableExpression><![CDATA[$F{VAT_AMOUNT}]]></variableExpression><initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression></variable>
    <variable name="VAT_EXEMPT_SALES_SUM" class="java.math.BigDecimal" calculation="Sum"><variableExpression><![CDATA[$F{VAT_EXEMPT_SALES}]]></variableExpression><initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression></variable>
    <variable name="ZERO_RATED_SALES_SUM" class="java.math.BigDecimal" calculation="Sum"><variableExpression><![CDATA[$F{ZERO_RATED_SALES}]]></variableExpression><initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression></variable>
    <variable name="WITHHOLDING_TAX_SUM" class="java.math.BigDecimal" calculation="Sum"><variableExpression><![CDATA[$F{WITHHOLDING_TAX_AMOUNT}]]></variableExpression><initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression></variable>
    <variable name="DISCOUNT_TOTAL_SUM" class="java.math.BigDecimal" calculation="Sum"><variableExpression><![CDATA[$F{DISCOUNT_TOTAL}]]></variableExpression><initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression></variable>
    <title>
        <band height="92">
            <textField><reportElement x="0" y="0" width="1040" height="20"/><textElement textAlignment="Center"><font size="14" isBold="true"/></textElement><textFieldExpression><![CDATA[$P{REPORT_TITLE}]]></textFieldExpression></textField>
            <textField><reportElement x="0" y="20" width="1040" height="16"/><textElement textAlignment="Center"><font size="10"/></textElement><textFieldExpression><![CDATA["Period: " + $P{DATE_FROM} + " to " + $P{DATE_TO}]]></textFieldExpression></textField>
            <textField><reportElement x="0" y="38" width="1040" height="16"/><textElement textAlignment="Center"><font size="10" isBold="true"/></textElement><textFieldExpression><![CDATA[$P{HEADER_REGISTERED_NAME} + ($P{HEADER_TRADE_NAME} == null || $P{HEADER_TRADE_NAME}.trim().isEmpty() ? "" : " / " + $P{HEADER_TRADE_NAME})]]></textFieldExpression></textField>
            <textField><reportElement x="0" y="54" width="1040" height="16"/><textElement textAlignment="Center"><font size="9"/></textElement><textFieldExpression><![CDATA["TIN: " + $P{HEADER_TIN} + ($P{HEADER_BRANCH_CODE} == null || $P{HEADER_BRANCH_CODE}.trim().isEmpty() ? "" : "    Branch: " + $P{HEADER_BRANCH_CODE}) + "    Address: " + $P{HEADER_BUSINESS_ADDRESS}]]></textFieldExpression></textField>
            <textField><reportElement x="0" y="70" width="1040" height="16"/><textElement textAlignment="Center"><font size="9"/></textElement><textFieldExpression><![CDATA["PTU No: " + $P{HEADER_PTU_NO} + "    ATP No: " + $P{HEADER_ATP_NO} + ($P{HEADER_POS_VENDOR} == null || $P{HEADER_POS_VENDOR}.trim().isEmpty() ? "" : "    POS Vendor: " + $P{HEADER_POS_VENDOR})]]></textFieldExpression></textField>
        </band>
    </title>
    <columnHeader>
        <band height="20">
            <staticText><reportElement x="0" y="0" width="75" height="20"/><text><![CDATA[Date]]></text></staticText>
            <staticText><reportElement x="75" y="0" width="55" height="20"/><text><![CDATA[Store]]></text></staticText>
            <staticText><reportElement x="130" y="0" width="60" height="20"/><text><![CDATA[Terminal]]></text></staticText>
            <staticText><reportElement x="190" y="0" width="60" height="20"/><text><![CDATA[Inv]]></text></staticText>
            <staticText><reportElement x="250" y="0" width="60" height="20"/><text><![CDATA[Void]]></text></staticText>
            <staticText><reportElement x="310" y="0" width="85" height="20"/><text><![CDATA[Gross]]></text></staticText>
            <staticText><reportElement x="395" y="0" width="85" height="20"/><text><![CDATA[Vatable]]></text></staticText>
            <staticText><reportElement x="480" y="0" width="80" height="20"/><text><![CDATA[VAT]]></text></staticText>
            <staticText><reportElement x="560" y="0" width="85" height="20"/><text><![CDATA[Exempt]]></text></staticText>
            <staticText><reportElement x="645" y="0" width="85" height="20"/><text><![CDATA[Zero]]></text></staticText>
            <staticText><reportElement x="730" y="0" width="90" height="20"/><text><![CDATA[W/Tax]]></text></staticText>
            <staticText><reportElement x="820" y="0" width="90" height="20"/><text><![CDATA[Discount]]></text></staticText>
            <staticText><reportElement x="910" y="0" width="130" height="20"/><text><![CDATA[Total Due]]></text></staticText>
        </band>
    </columnHeader>
    <detail>
        <band height="20">
            <rectangle>
                <reportElement x="0" y="0" width="1040" height="20" mode="Opaque" backcolor="#F2F2F2">
                    <printWhenExpression><![CDATA[Boolean.valueOf($V{REPORT_COUNT}.intValue() % 2 == 0)]]></printWhenExpression>
                </reportElement>
                <graphicElement/>
            </rectangle>
            <textField pattern="yyyy-MM-dd"><reportElement x="0" y="0" width="75" height="20"/><textFieldExpression><![CDATA[$F{BUSINESS_DATE}]]></textFieldExpression></textField>
            <textField><reportElement x="75" y="0" width="55" height="20"/><textFieldExpression><![CDATA[$F{STORE_CODE}]]></textFieldExpression></textField>
            <textField><reportElement x="130" y="0" width="60" height="20"/><textFieldExpression><![CDATA[$F{TERMINAL_CODE}]]></textFieldExpression></textField>
            <textField><reportElement x="190" y="0" width="60" height="20"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{INVOICE_COUNT}]]></textFieldExpression></textField>
            <textField><reportElement x="250" y="0" width="60" height="20"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{VOID_INVOICE_COUNT}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="310" y="0" width="85" height="20"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{GROSS_SALES}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="395" y="0" width="85" height="20"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{VATABLE_SALES}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="480" y="0" width="80" height="20"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{VAT_AMOUNT}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="560" y="0" width="85" height="20"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{VAT_EXEMPT_SALES}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="645" y="0" width="85" height="20"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{ZERO_RATED_SALES}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="730" y="0" width="90" height="20"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{WITHHOLDING_TAX_AMOUNT}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="820" y="0" width="90" height="20"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{DISCOUNT_TOTAL}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="910" y="0" width="130" height="20"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{TOTAL_AMOUNT_DUE}]]></textFieldExpression></textField>
        </band>
    </detail>

    <pageFooter>
        <band height="18">
            <textField><reportElement x="0" y="0" width="520" height="16"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA["Printed By: " + $P{PRINTED_BY}]]></textFieldExpression></textField>
            <textField><reportElement x="520" y="0" width="520" height="16"/><textElement textAlignment="Right"><font size="9"/></textElement><textFieldExpression><![CDATA["Printed At: " + $P{PRINTED_AT}]]></textFieldExpression></textField>
        </band>
    </pageFooter>


    <summary>
        <band height="72">
            <line><reportElement x="0" y="0" width="1040" height="1"/></line>
            <staticText><reportElement x="470" y="6" width="150" height="18"/><textElement textAlignment="Right"><font isBold="true"/></textElement><text><![CDATA[Grand Total Gross Sales:]]></text></staticText>
            <textField pattern="#,##0.00"><reportElement x="620" y="6" width="120" height="18"/><textElement textAlignment="Right"><font isBold="true"/></textElement><textFieldExpression><![CDATA[$V{GROSS_SALES_SUM}]]></textFieldExpression></textField>
            <staticText><reportElement x="750" y="6" width="150" height="18"/><textElement textAlignment="Right"><font isBold="true"/></textElement><text><![CDATA[Grand Total Vatable Sales:]]></text></staticText>
            <textField pattern="#,##0.00"><reportElement x="900" y="6" width="140" height="18"/><textElement textAlignment="Right"><font isBold="true"/></textElement><textFieldExpression><![CDATA[$V{VATABLE_SALES_SUM}]]></textFieldExpression></textField>
            <staticText><reportElement x="470" y="28" width="150" height="18"/><textElement textAlignment="Right"><font isBold="true"/></textElement><text><![CDATA[Grand Total VAT Amount:]]></text></staticText>
            <textField pattern="#,##0.00"><reportElement x="620" y="28" width="120" height="18"/><textElement textAlignment="Right"><font isBold="true"/></textElement><textFieldExpression><![CDATA[$V{VAT_AMOUNT_SUM}]]></textFieldExpression></textField>
            <staticText><reportElement x="750" y="28" width="150" height="18"/><textElement textAlignment="Right"><font isBold="true"/></textElement><text><![CDATA[Grand Total VAT Exempt:]]></text></staticText>
            <textField pattern="#,##0.00"><reportElement x="900" y="28" width="140" height="18"/><textElement textAlignment="Right"><font isBold="true"/></textElement><textFieldExpression><![CDATA[$V{VAT_EXEMPT_SALES_SUM}]]></textFieldExpression></textField>
            <staticText><reportElement x="470" y="50" width="150" height="18"/><textElement textAlignment="Right"><font isBold="true"/></textElement><text><![CDATA[Grand Total Zero Rated:]]></text></staticText>
            <textField pattern="#,##0.00"><reportElement x="620" y="50" width="120" height="18"/><textElement textAlignment="Right"><font isBold="true"/></textElement><textFieldExpression><![CDATA[$V{ZERO_RATED_SALES_SUM}]]></textFieldExpression></textField>
            <staticText><reportElement x="750" y="50" width="150" height="18"/><textElement textAlignment="Right"><font isBold="true"/></textElement><text><![CDATA[Grand Total W/Tax:]]></text></staticText>
            <textField pattern="#,##0.00"><reportElement x="900" y="50" width="140" height="18"/><textElement textAlignment="Right"><font isBold="true"/></textElement><textFieldExpression><![CDATA[$V{WITHHOLDING_TAX_SUM}]]></textFieldExpression></textField>
            <staticText><reportElement x="40" y="50" width="220" height="18"/><textElement textAlignment="Right"><font isBold="true"/></textElement><text><![CDATA[Grand Total Discount:]]></text></staticText>
            <textField pattern="#,##0.00"><reportElement x="260" y="50" width="140" height="18"/><textElement textAlignment="Right"><font isBold="true"/></textElement><textFieldExpression><![CDATA[$V{DISCOUNT_TOTAL_SUM}]]></textFieldExpression></textField>
        </band>
    </summary>

    </jasperReport>
