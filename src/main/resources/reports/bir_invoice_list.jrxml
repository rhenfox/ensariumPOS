<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="bir_invoice_list" pageWidth="1220" pageHeight="595" orientation="Landscape" columnWidth="1180" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
    <parameter name="REPORT_TITLE" class="java.lang.String"/>
    <parameter name="DATE_FROM" class="java.sql.Date"/>
    <parameter name="DATE_TO" class="java.sql.Date"/>
    <parameter name="HEADER_REGISTERED_NAME" class="java.lang.String"/>
    <parameter name="HEADER_TRADE_NAME" class="java.lang.String"/>
    <parameter name="HEADER_TIN" class="java.lang.String"/>
    <parameter name="HEADER_BRANCH_CODE" class="java.lang.String"/>
    <parameter name="HEADER_BUSINESS_ADDRESS" class="java.lang.String"/>
    <parameter name="HEADER_PTU_NO" class="java.lang.String"/>
    <parameter name="HEADER_ATP_NO" class="java.lang.String"/>
    <parameter name="HEADER_POS_VENDOR" class="java.lang.String"/>
    <parameter name="PRINTED_BY" class="java.lang.String"/>
    <parameter name="PRINTED_AT" class="java.lang.String"/>
    <queryString><![CDATA[
        SELECT invoice_no AS INVOICE_NO,
               invoice_date AS INVOICE_DATE,
               store_code AS STORE_CODE,
               terminal_code AS TERMINAL_CODE,
               seller_tin_no || '-' || seller_branch_code AS SELLER_TIN_BRANCH,
               buyer_registered_name AS BUYER_NAME,
               buyer_tin_no AS BUYER_TIN_NO,
               bir_permit_to_use_no AS PTU_NO,
               atp_no AS ATP_NO,
               gross_sales AS GROSS_SALES,
               vatable_sales AS VATABLE_SALES,
               vat_amount AS VAT_AMOUNT,
               vat_exempt_sales AS VAT_EXEMPT_SALES,
               zero_rated_sales AS ZERO_RATED_SALES,
               discount_total AS DISCOUNT_TOTAL,
               total_amount_due AS TOTAL_AMOUNT_DUE
        FROM v_bir_invoice_list
        WHERE invoice_date BETWEEN $P{DATE_FROM} AND $P{DATE_TO}
        ORDER BY invoice_date, invoice_no
    ]]></queryString>
    <field name="INVOICE_NO" class="java.lang.String"/>
    <field name="INVOICE_DATE" class="java.sql.Date"/>
    <field name="STORE_CODE" class="java.lang.String"/>
    <field name="TERMINAL_CODE" class="java.lang.String"/>
    <field name="SELLER_TIN_BRANCH" class="java.lang.String"/>
    <field name="BUYER_NAME" class="java.lang.String"/>
    <field name="BUYER_TIN_NO" class="java.lang.String"/>
    <field name="PTU_NO" class="java.lang.String"/>
    <field name="ATP_NO" class="java.lang.String"/>
    <field name="GROSS_SALES" class="java.math.BigDecimal"/>
    <field name="VATABLE_SALES" class="java.math.BigDecimal"/>
    <field name="VAT_AMOUNT" class="java.math.BigDecimal"/>
    <field name="VAT_EXEMPT_SALES" class="java.math.BigDecimal"/>
    <field name="ZERO_RATED_SALES" class="java.math.BigDecimal"/>
    <field name="DISCOUNT_TOTAL" class="java.math.BigDecimal"/>
    <field name="TOTAL_AMOUNT_DUE" class="java.math.BigDecimal"/>
    <variable name="GROSS_SALES_SUM" class="java.math.BigDecimal" calculation="Sum"><variableExpression><![CDATA[$F{GROSS_SALES}]]></variableExpression><initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression></variable>
    <variable name="VATABLE_SALES_SUM" class="java.math.BigDecimal" calculation="Sum"><variableExpression><![CDATA[$F{VATABLE_SALES}]]></variableExpression><initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression></variable>
    <variable name="VAT_AMOUNT_SUM" class="java.math.BigDecimal" calculation="Sum"><variableExpression><![CDATA[$F{VAT_AMOUNT}]]></variableExpression><initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression></variable>
    <variable name="VAT_EXEMPT_SALES_SUM" class="java.math.BigDecimal" calculation="Sum"><variableExpression><![CDATA[$F{VAT_EXEMPT_SALES}]]></variableExpression><initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression></variable>
    <title>
        <band height="92">
            <textField><reportElement x="0" y="0" width="1180" height="20"/><textElement textAlignment="Center"><font size="14" isBold="true"/></textElement><textFieldExpression><![CDATA[$P{REPORT_TITLE}]]></textFieldExpression></textField>
            <textField><reportElement x="0" y="20" width="1180" height="16"/><textElement textAlignment="Center"><font size="10"/></textElement><textFieldExpression><![CDATA["Period: " + $P{DATE_FROM} + " to " + $P{DATE_TO}]]></textFieldExpression></textField>
            <textField><reportElement x="0" y="38" width="1180" height="16"/><textElement textAlignment="Center"><font size="10" isBold="true"/></textElement><textFieldExpression><![CDATA[$P{HEADER_REGISTERED_NAME} + ($P{HEADER_TRADE_NAME} == null || $P{HEADER_TRADE_NAME}.trim().isEmpty() ? "" : " / " + $P{HEADER_TRADE_NAME})]]></textFieldExpression></textField>
            <textField><reportElement x="0" y="54" width="1180" height="16"/><textElement textAlignment="Center"><font size="9"/></textElement><textFieldExpression><![CDATA["TIN: " + $P{HEADER_TIN} + ($P{HEADER_BRANCH_CODE} == null || $P{HEADER_BRANCH_CODE}.trim().isEmpty() ? "" : "    Branch: " + $P{HEADER_BRANCH_CODE}) + "    Address: " + $P{HEADER_BUSINESS_ADDRESS}]]></textFieldExpression></textField>
            <textField><reportElement x="0" y="70" width="1180" height="16"/><textElement textAlignment="Center"><font size="9"/></textElement><textFieldExpression><![CDATA["PTU No: " + $P{HEADER_PTU_NO} + "    ATP No: " + $P{HEADER_ATP_NO} + ($P{HEADER_POS_VENDOR} == null || $P{HEADER_POS_VENDOR}.trim().isEmpty() ? "" : "    POS Vendor: " + $P{HEADER_POS_VENDOR})]]></textFieldExpression></textField>
        </band>
    </title>
    <columnHeader>
        <band height="20">
            <staticText><reportElement x="0" y="0" width="80" height="20"/><text><![CDATA[Invoice No]]></text></staticText>
            <staticText><reportElement x="80" y="0" width="70" height="20"/><text><![CDATA[Date]]></text></staticText>
            <staticText><reportElement x="150" y="0" width="55" height="20"/><text><![CDATA[Store]]></text></staticText>
            <staticText><reportElement x="205" y="0" width="60" height="20"/><text><![CDATA[Terminal]]></text></staticText>
            <staticText><reportElement x="265" y="0" width="110" height="20"/><text><![CDATA[TIN/Branch]]></text></staticText>
            <staticText><reportElement x="375" y="0" width="150" height="20"/><text><![CDATA[Buyer]]></text></staticText>
            <staticText><reportElement x="525" y="0" width="90" height="20"/><text><![CDATA[Buyer TIN]]></text></staticText>
            <staticText><reportElement x="615" y="0" width="95" height="20"/><text><![CDATA[PTU]]></text></staticText>
            <staticText><reportElement x="710" y="0" width="95" height="20"/><text><![CDATA[ATP]]></text></staticText>
            <staticText><reportElement x="805" y="0" width="75" height="20"/><text><![CDATA[Gross]]></text></staticText>
            <staticText><reportElement x="880" y="0" width="75" height="20"/><text><![CDATA[Vatable]]></text></staticText>
            <staticText><reportElement x="955" y="0" width="70" height="20"/><text><![CDATA[VAT]]></text></staticText>
            <staticText><reportElement x="1025" y="0" width="70" height="20"/><text><![CDATA[Exempt]]></text></staticText>
            <staticText><reportElement x="1095" y="0" width="70" height="20"/><text><![CDATA[Zero]]></text></staticText>
        </band>
    </columnHeader>
    <detail>
        <band height="36">
            <rectangle>
                <reportElement x="0" y="0" width="1180" height="36" mode="Opaque" backcolor="#F2F2F2">
                    <printWhenExpression><![CDATA[Boolean.valueOf($V{REPORT_COUNT}.intValue() % 2 == 0)]]></printWhenExpression>
                </reportElement>
                <graphicElement/>
            </rectangle>
            <textField><reportElement x="0" y="0" width="80" height="18"/><textFieldExpression><![CDATA[$F{INVOICE_NO}]]></textFieldExpression></textField>
            <textField pattern="yyyy-MM-dd"><reportElement x="80" y="0" width="70" height="18"/><textFieldExpression><![CDATA[$F{INVOICE_DATE}]]></textFieldExpression></textField>
            <textField><reportElement x="150" y="0" width="55" height="18"/><textFieldExpression><![CDATA[$F{STORE_CODE}]]></textFieldExpression></textField>
            <textField><reportElement x="205" y="0" width="60" height="18"/><textFieldExpression><![CDATA[$F{TERMINAL_CODE}]]></textFieldExpression></textField>
            <textField><reportElement x="265" y="0" width="110" height="18"/><textFieldExpression><![CDATA[$F{SELLER_TIN_BRANCH}]]></textFieldExpression></textField>
            <textField><reportElement x="375" y="0" width="150" height="18"/><textFieldExpression><![CDATA[$F{BUYER_NAME}]]></textFieldExpression></textField>
            <textField><reportElement x="525" y="0" width="90" height="18"/><textFieldExpression><![CDATA[$F{BUYER_TIN_NO}]]></textFieldExpression></textField>
            <textField><reportElement x="615" y="0" width="95" height="18"/><textFieldExpression><![CDATA[$F{PTU_NO}]]></textFieldExpression></textField>
            <textField><reportElement x="710" y="0" width="95" height="18"/><textFieldExpression><![CDATA[$F{ATP_NO}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="805" y="0" width="75" height="18"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{GROSS_SALES}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="880" y="0" width="75" height="18"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{VATABLE_SALES}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="955" y="0" width="70" height="18"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{VAT_AMOUNT}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="1025" y="0" width="70" height="18"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{VAT_EXEMPT_SALES}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="1095" y="0" width="70" height="18"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{ZERO_RATED_SALES}]]></textFieldExpression></textField>
            <staticText><reportElement x="805" y="18" width="75" height="16"/><textElement><font size="8"/></textElement><text><![CDATA[Disc.]]></text></staticText>
            <textField pattern="#,##0.00"><reportElement x="880" y="18" width="75" height="16"/><textElement textAlignment="Right"><font size="8"/></textElement><textFieldExpression><![CDATA[$F{DISCOUNT_TOTAL}]]></textFieldExpression></textField>
            <staticText><reportElement x="955" y="18" width="70" height="16"/><textElement><font size="8"/></textElement><text><![CDATA[Total Due]]></text></staticText>
            <textField pattern="#,##0.00"><reportElement x="1025" y="18" width="140" height="16"/><textElement textAlignment="Right"><font size="8"/></textElement><textFieldExpression><![CDATA[$F{TOTAL_AMOUNT_DUE}]]></textFieldExpression></textField>
        </band>
    </detail>

    <pageFooter>
        <band height="18">
            <textField><reportElement x="0" y="0" width="590" height="16"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA["Printed By: " + $P{PRINTED_BY}]]></textFieldExpression></textField>
            <textField><reportElement x="590" y="0" width="590" height="16"/><textElement textAlignment="Right"><font size="9"/></textElement><textFieldExpression><![CDATA["Printed At: " + $P{PRINTED_AT}]]></textFieldExpression></textField>
        </band>
    </pageFooter>


    <summary>
        <band height="50">
            <line><reportElement x="0" y="0" width="1180" height="1"/></line>
            <staticText><reportElement x="540" y="6" width="160" height="18"/><textElement textAlignment="Right"><font isBold="true"/></textElement><text><![CDATA[Grand Total Gross Sales:]]></text></staticText>
            <textField pattern="#,##0.00"><reportElement x="700" y="6" width="120" height="18"/><textElement textAlignment="Right"><font isBold="true"/></textElement><textFieldExpression><![CDATA[$V{GROSS_SALES_SUM}]]></textFieldExpression></textField>
            <staticText><reportElement x="830" y="6" width="160" height="18"/><textElement textAlignment="Right"><font isBold="true"/></textElement><text><![CDATA[Grand Total Vatable Sales:]]></text></staticText>
            <textField pattern="#,##0.00"><reportElement x="1000" y="6" width="165" height="18"/><textElement textAlignment="Right"><font isBold="true"/></textElement><textFieldExpression><![CDATA[$V{VATABLE_SALES_SUM}]]></textFieldExpression></textField>
            <staticText><reportElement x="540" y="28" width="160" height="18"/><textElement textAlignment="Right"><font isBold="true"/></textElement><text><![CDATA[Grand Total VAT Amount:]]></text></staticText>
            <textField pattern="#,##0.00"><reportElement x="700" y="28" width="120" height="18"/><textElement textAlignment="Right"><font isBold="true"/></textElement><textFieldExpression><![CDATA[$V{VAT_AMOUNT_SUM}]]></textFieldExpression></textField>
            <staticText><reportElement x="830" y="28" width="160" height="18"/><textElement textAlignment="Right"><font isBold="true"/></textElement><text><![CDATA[Grand Total VAT Exempt:]]></text></staticText>
            <textField pattern="#,##0.00"><reportElement x="1000" y="28" width="165" height="18"/><textElement textAlignment="Right"><font isBold="true"/></textElement><textFieldExpression><![CDATA[$V{VAT_EXEMPT_SALES_SUM}]]></textFieldExpression></textField>
        </band>
    </summary>

    </jasperReport>
