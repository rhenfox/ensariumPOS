<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="pos_profit" pageWidth="1080" pageHeight="595" orientation="Landscape" columnWidth="1040" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
    <parameter name="REPORT_TITLE" class="java.lang.String"/>
    <parameter name="DATE_FROM" class="java.sql.Date"/>
    <parameter name="DATE_TO" class="java.sql.Date"/>
    <parameter name="HEADER_REGISTERED_NAME" class="java.lang.String"/>
    <parameter name="HEADER_TRADE_NAME" class="java.lang.String"/>
    <parameter name="HEADER_TIN" class="java.lang.String"/>
    <parameter name="HEADER_BRANCH_CODE" class="java.lang.String"/>
    <parameter name="HEADER_BUSINESS_ADDRESS" class="java.lang.String"/>
    <parameter name="HEADER_PTU_NO" class="java.lang.String"/>
    <parameter name="HEADER_ATP_NO" class="java.lang.String"/>
    <parameter name="HEADER_POS_VENDOR" class="java.lang.String"/>
    <parameter name="PRINTED_BY" class="java.lang.String"/>
    <parameter name="PRINTED_AT" class="java.lang.String"/>
    <queryString><![CDATA[
        SELECT sale_no AS SALE_NO,
               business_date AS BUSINESS_DATE,
               store_code AS STORE_CODE,
               terminal_code AS TERMINAL_CODE,
               invoice_no AS INVOICE_NO,
               customer_name AS CUSTOMER_NAME,
               gross_amount AS GROSS_AMOUNT,
               discount_total AS DISCOUNT_TOTAL,
               tax_total AS TAX_TOTAL,
               net_sales AS NET_SALES,
               cost_of_goods_sold AS COST_OF_GOODS_SOLD,
               gross_profit AS GROSS_PROFIT,
               profit_margin_pct AS PROFIT_MARGIN_PCT
        FROM v_pos_profit_report
        WHERE business_date BETWEEN $P{DATE_FROM} AND $P{DATE_TO}
        ORDER BY business_date, sale_no
    ]]></queryString>
    <field name="SALE_NO" class="java.lang.String"/>
    <field name="BUSINESS_DATE" class="java.sql.Date"/>
    <field name="STORE_CODE" class="java.lang.String"/>
    <field name="TERMINAL_CODE" class="java.lang.String"/>
    <field name="INVOICE_NO" class="java.lang.String"/>
    <field name="CUSTOMER_NAME" class="java.lang.String"/>
    <field name="GROSS_AMOUNT" class="java.math.BigDecimal"/>
    <field name="DISCOUNT_TOTAL" class="java.math.BigDecimal"/>
    <field name="TAX_TOTAL" class="java.math.BigDecimal"/>
    <field name="NET_SALES" class="java.math.BigDecimal"/>
    <field name="COST_OF_GOODS_SOLD" class="java.math.BigDecimal"/>
    <field name="GROSS_PROFIT" class="java.math.BigDecimal"/>
    <field name="PROFIT_MARGIN_PCT" class="java.math.BigDecimal"/>
    <variable name="GROSS_AMOUNT_SUM" class="java.math.BigDecimal" calculation="Sum"><variableExpression><![CDATA[$F{GROSS_AMOUNT}]]></variableExpression><initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression></variable>
    <variable name="DISCOUNT_TOTAL_SUM" class="java.math.BigDecimal" calculation="Sum"><variableExpression><![CDATA[$F{DISCOUNT_TOTAL}]]></variableExpression><initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression></variable>
    <variable name="TAX_TOTAL_SUM" class="java.math.BigDecimal" calculation="Sum"><variableExpression><![CDATA[$F{TAX_TOTAL}]]></variableExpression><initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression></variable>
    <variable name="NET_SALES_SUM" class="java.math.BigDecimal" calculation="Sum"><variableExpression><![CDATA[$F{NET_SALES}]]></variableExpression><initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression></variable>
    <variable name="COGS_SUM" class="java.math.BigDecimal" calculation="Sum"><variableExpression><![CDATA[$F{COST_OF_GOODS_SOLD}]]></variableExpression><initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression></variable>
    <variable name="GROSS_PROFIT_SUM" class="java.math.BigDecimal" calculation="Sum"><variableExpression><![CDATA[$F{GROSS_PROFIT}]]></variableExpression><initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression></variable>
    <title>
        <band height="92">
            <textField><reportElement x="0" y="0" width="1040" height="20"/><textElement textAlignment="Center"><font size="14" isBold="true"/></textElement><textFieldExpression><![CDATA[$P{REPORT_TITLE}]]></textFieldExpression></textField>
            <textField><reportElement x="0" y="20" width="1040" height="16"/><textElement textAlignment="Center"><font size="10"/></textElement><textFieldExpression><![CDATA["Period: " + $P{DATE_FROM} + " to " + $P{DATE_TO}]]></textFieldExpression></textField>
            <textField><reportElement x="0" y="38" width="1040" height="16"/><textElement textAlignment="Center"><font size="10" isBold="true"/></textElement><textFieldExpression><![CDATA[$P{HEADER_REGISTERED_NAME} + ($P{HEADER_TRADE_NAME} == null || $P{HEADER_TRADE_NAME}.trim().isEmpty() ? "" : " / " + $P{HEADER_TRADE_NAME})]]></textFieldExpression></textField>
            <textField><reportElement x="0" y="54" width="1040" height="16"/><textElement textAlignment="Center"><font size="9"/></textElement><textFieldExpression><![CDATA["TIN: " + $P{HEADER_TIN} + ($P{HEADER_BRANCH_CODE} == null || $P{HEADER_BRANCH_CODE}.trim().isEmpty() ? "" : "    Branch: " + $P{HEADER_BRANCH_CODE}) + "    Address: " + $P{HEADER_BUSINESS_ADDRESS}]]></textFieldExpression></textField>
            <textField><reportElement x="0" y="70" width="1040" height="16"/><textElement textAlignment="Center"><font size="9"/></textElement><textFieldExpression><![CDATA["PTU No: " + $P{HEADER_PTU_NO} + "    ATP No: " + $P{HEADER_ATP_NO} + ($P{HEADER_POS_VENDOR} == null || $P{HEADER_POS_VENDOR}.trim().isEmpty() ? "" : "    POS Vendor: " + $P{HEADER_POS_VENDOR})]]></textFieldExpression></textField>
        </band>
    </title>
    <columnHeader>
        <band height="20">
            <staticText><reportElement x="0" y="0" width="80" height="20"/><text><![CDATA[Sale No]]></text></staticText>
            <staticText><reportElement x="80" y="0" width="75" height="20"/><text><![CDATA[Date]]></text></staticText>
            <staticText><reportElement x="155" y="0" width="55" height="20"/><text><![CDATA[Store]]></text></staticText>
            <staticText><reportElement x="210" y="0" width="60" height="20"/><text><![CDATA[Terminal]]></text></staticText>
            <staticText><reportElement x="270" y="0" width="85" height="20"/><text><![CDATA[Invoice]]></text></staticText>
            <staticText><reportElement x="355" y="0" width="135" height="20"/><text><![CDATA[Customer]]></text></staticText>
            <staticText><reportElement x="490" y="0" width="80" height="20"/><text><![CDATA[Gross]]></text></staticText>
            <staticText><reportElement x="570" y="0" width="70" height="20"/><text><![CDATA[Disc]]></text></staticText>
            <staticText><reportElement x="640" y="0" width="70" height="20"/><text><![CDATA[Tax]]></text></staticText>
            <staticText><reportElement x="710" y="0" width="80" height="20"/><text><![CDATA[Net Sales]]></text></staticText>
            <staticText><reportElement x="790" y="0" width="80" height="20"/><text><![CDATA[COGS]]></text></staticText>
            <staticText><reportElement x="870" y="0" width="90" height="20"/><text><![CDATA[Gross Profit]]></text></staticText>
            <staticText><reportElement x="960" y="0" width="80" height="20"/><text><![CDATA[Margin %]]></text></staticText>
        </band>
    </columnHeader>
    <detail>
        <band height="20">
            <rectangle>
                <reportElement x="0" y="0" width="1040" height="20" mode="Opaque" backcolor="#F2F2F2">
                    <printWhenExpression><![CDATA[Boolean.valueOf($V{REPORT_COUNT}.intValue() % 2 == 0)]]></printWhenExpression>
                </reportElement>
                <graphicElement/>
            </rectangle>
            <textField><reportElement x="0" y="0" width="80" height="20"/><textFieldExpression><![CDATA[$F{SALE_NO}]]></textFieldExpression></textField>
            <textField pattern="yyyy-MM-dd"><reportElement x="80" y="0" width="75" height="20"/><textFieldExpression><![CDATA[$F{BUSINESS_DATE}]]></textFieldExpression></textField>
            <textField><reportElement x="155" y="0" width="55" height="20"/><textFieldExpression><![CDATA[$F{STORE_CODE}]]></textFieldExpression></textField>
            <textField><reportElement x="210" y="0" width="60" height="20"/><textFieldExpression><![CDATA[$F{TERMINAL_CODE}]]></textFieldExpression></textField>
            <textField><reportElement x="270" y="0" width="85" height="20"/><textFieldExpression><![CDATA[$F{INVOICE_NO}]]></textFieldExpression></textField>
            <textField><reportElement x="355" y="0" width="135" height="20"/><textFieldExpression><![CDATA[$F{CUSTOMER_NAME}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="490" y="0" width="80" height="20"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{GROSS_AMOUNT}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="570" y="0" width="70" height="20"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{DISCOUNT_TOTAL}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="640" y="0" width="70" height="20"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{TAX_TOTAL}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="710" y="0" width="80" height="20"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{NET_SALES}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="790" y="0" width="80" height="20"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{COST_OF_GOODS_SOLD}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="870" y="0" width="90" height="20"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{GROSS_PROFIT}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="960" y="0" width="80" height="20"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{PROFIT_MARGIN_PCT}]]></textFieldExpression></textField>
        </band>
    </detail>

    <pageFooter>
        <band height="18">
            <textField><reportElement x="0" y="0" width="520" height="16"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA["Printed By: " + $P{PRINTED_BY}]]></textFieldExpression></textField>
            <textField><reportElement x="520" y="0" width="520" height="16"/><textElement textAlignment="Right"><font size="9"/></textElement><textFieldExpression><![CDATA["Printed At: " + $P{PRINTED_AT}]]></textFieldExpression></textField>
        </band>
    </pageFooter>


    <summary>
        <band height="72">
            <line><reportElement x="0" y="0" width="1040" height="1"/></line>
            <staticText><reportElement x="350" y="6" width="140" height="18"/><textElement textAlignment="Right"><font isBold="true"/></textElement><text><![CDATA[Grand Total Gross:]]></text></staticText>
            <textField pattern="#,##0.00"><reportElement x="490" y="6" width="120" height="18"/><textElement textAlignment="Right"><font isBold="true"/></textElement><textFieldExpression><![CDATA[$V{GROSS_AMOUNT_SUM}]]></textFieldExpression></textField>
            <staticText><reportElement x="620" y="6" width="140" height="18"/><textElement textAlignment="Right"><font isBold="true"/></textElement><text><![CDATA[Grand Total Discount:]]></text></staticText>
            <textField pattern="#,##0.00"><reportElement x="760" y="6" width="120" height="18"/><textElement textAlignment="Right"><font isBold="true"/></textElement><textFieldExpression><![CDATA[$V{DISCOUNT_TOTAL_SUM}]]></textFieldExpression></textField>
            <staticText><reportElement x="890" y="6" width="60" height="18"/><textElement textAlignment="Right"><font isBold="true"/></textElement><text><![CDATA[Tax:]]></text></staticText>
            <textField pattern="#,##0.00"><reportElement x="950" y="6" width="90" height="18"/><textElement textAlignment="Right"><font isBold="true"/></textElement><textFieldExpression><![CDATA[$V{TAX_TOTAL_SUM}]]></textFieldExpression></textField>
            <staticText><reportElement x="350" y="28" width="140" height="18"/><textElement textAlignment="Right"><font isBold="true"/></textElement><text><![CDATA[Grand Total Net Sales:]]></text></staticText>
            <textField pattern="#,##0.00"><reportElement x="490" y="28" width="120" height="18"/><textElement textAlignment="Right"><font isBold="true"/></textElement><textFieldExpression><![CDATA[$V{NET_SALES_SUM}]]></textFieldExpression></textField>
            <staticText><reportElement x="620" y="28" width="140" height="18"/><textElement textAlignment="Right"><font isBold="true"/></textElement><text><![CDATA[Grand Total COGS:]]></text></staticText>
            <textField pattern="#,##0.00"><reportElement x="760" y="28" width="120" height="18"/><textElement textAlignment="Right"><font isBold="true"/></textElement><textFieldExpression><![CDATA[$V{COGS_SUM}]]></textFieldExpression></textField>
            <staticText><reportElement x="890" y="28" width="60" height="18"/><textElement textAlignment="Right"><font isBold="true"/></textElement><text><![CDATA[Profit:]]></text></staticText>
            <textField pattern="#,##0.00"><reportElement x="950" y="28" width="90" height="18"/><textElement textAlignment="Right"><font isBold="true"/></textElement><textFieldExpression><![CDATA[$V{GROSS_PROFIT_SUM}]]></textFieldExpression></textField>
        </band>
    </summary>

